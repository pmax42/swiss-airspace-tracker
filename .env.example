# OpenSky Network API Credentials
# Register at https://opensky-network.org/ to get these credentials
OPENSKY_CLIENT_ID=your_opensky_client_id
OPENSKY_CLIENT_SECRET=your_opensky_client_secret

# PostgreSQL Database Configuration
DB_USER=admin
DB_PASSWORD=your_secure_password
DB_HOST=db
DB_NAME=flight_tracker

# API Host Configuration
# Use "api" for Docker, "localhost" for local development
API_HOST=api

# Proxy Configuration (Optional)
# Only required if deploying to AWS or behind a corporate proxy
PROXY_HOST=
PROXY_PORT=
PROXY_USER=
PROXY_PASS=

# Streamlit UI Configuration (Optional)
# Set to "true" to hide the top bar in production
STREAMLIT_UI_HIDE_TOP_BAR=false

# Streamlit Toolbar Mode (Optional)
# Set to "viewer" in production to restrict user interactions
STREAMLIT_CLIENT_TOOLBAR_MODE=auto
